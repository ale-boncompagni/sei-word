{
  "manifest_version": 3,
  "name": "SEI para Word",
  "version": "2.0",
  "description": "Extensão para converter documentos internos do SEI em formato Word, preservando cabeçalho, rodapé, numeração e formatação originais.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "*://sei.pr.gov.br/*",
    "*://sei.caupr.gov.br/*",
    "*://sei.caubr.gov.br/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://sei.pr.gov.br/*", "*://sei.caupr.gov.br/*", "*://sei.caubr.gov.br/*"],
      "js": ["content.bundle.js"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/export-word-icon.png"
      ],
      "matches": [
        "*://sei.pr.gov.br/*",
        "*://sei.caupr.gov.br/*",
        "*://sei.caubr.gov.br/*"
      ]
    }
  ]
} 